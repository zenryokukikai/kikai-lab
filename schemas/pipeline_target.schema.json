{
  "$id": "https://kikai-lab.local/schemas/pipeline_target.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "external_refs": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "project_id": {
      "type": "string"
    },
    "schema_version": {
      "minimum": 1,
      "type": "integer"
    },
    "status": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "target_id": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "target_id"
  ],
  "title": "Kikai Lab Pipeline Target",
  "type": "object"
}
